DOCKSAL_STACK=default
DOCROOT="."

# Lock images versions for LAMP services
# This will prevent images from being updated when Docksal is updated
WEB_IMAGE='docksal/web:2.1-apache2.4'
DB_IMAGE='docksal/db:1.1-mysql-5.6'
CLI_IMAGE='docksal/cli:php8.3-3.11' #PHP 8.3
#CLI_IMAGE='docksal/cli:php8.2-3.11' PHP 8.2

# Enable/disable xdebug; 1 is "on"
#XDEBUG_ENABLED=1
