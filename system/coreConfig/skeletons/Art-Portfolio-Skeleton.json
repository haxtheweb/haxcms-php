          "order": 1,
          "parent": null,
          "indent": 0,
          "content": "<h2>Featured Works</h2><media-image source=\"https://media.surrealismtoday.com/wp-content/uploads/2020/07/12183324/Iteration-29-Age-of-Enlightenment-2-vincent-fink.jpg\" card citation=\"Sacred Mind\" accent-color=\"grey\" size=\"wide\"></media-image><media-image source=\"https://images.rawpixel.com/image_800/cHJpdmF0ZS9sci9pbWFnZXMvd2Vic2l0ZS8yMDIyLTExL3BkbWlzYzctd2szODY1ODEyNS1pbWFnZV8xLmpwZw.jpg\" card citation=\"Formed / Shaped\" accent-color=\"grey\" size=\"wide\"></media-image><media-image source=\"https://images.zenmuseum.com/page/generic/art-movements/49088374138_162d554940_c.jpg\" card citation=\"Simplicity\" accent-color=\"grey\" size=\"wide\"></media-image><media-image source=\"https://media.easy-peasy.ai/27feb2bb-aeb4-4a83-9fb6-8f3f2a15885e/bc4f430d-50d6-4c70-86be-f6b874604fa0.png\" card citation=\"Diluted\" accent-color=\"grey\" size=\"wide\"></media-image>",
